{
  "version": 2,
  "builds": [
    { "src": "api/api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/admin/login", "dest": "api/api/index.py" },
    { "src": "/api/upload", "dest": "api/api/index.py" },
    { "src": "/api/produtos", "dest": "api/api/index.py" },
    { "src": "/api/produtos/(.*)", "dest": "api/api/index.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
